<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="MAIN" Id="{a004adcc-e612-47ae-a4a7-791cfb6ba3d0}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM MAIN
VAR
  // --- System time (used by every FB_SqlLogger) ---
  fbLocalSystemTime : FB_LocalSystemTime;

  // --- Sensor values: replace these with your real signal variables ---
  rTemperature : REAL := 22.5;   // id=1
  rHumidity    : REAL := 55.0;   // id=2
  rSpeed       : REAL := 1450.0; // id=3

  // --- One logger per channel ---
  fbLogTemp  : FB_SqlLogger;
  fbLogHumid : FB_SqlLogger;
  fbLogSpeed : FB_SqlLogger;

  // --- Read back: set bSelect := TRUE to fetch the last 1000 rows ---
  fbSelectDb     : FB_SQLDatabaseEvt(sNetID := '', tTimeout := T#30S);
  fbSelectCmd    : FB_SQLCommandEvt(sNetID := '', tTimeout := T#30S);
  fbSelectResult : FB_SQLResultEvt(sNetID := '', tTimeout := T#30S);
  sSelectCmd     : STRING(255) := 'SELECT id, timestamp, value FROM ds ORDER BY timestamp DESC LIMIT 1000';
  bSelect        : BOOL;
  bSelectBusy    : BOOL;
  bSelectError   : BOOL;
  nSelectState   : INT; // 0=idle,1=connect,2=createCmd,3=execute,4=read,5=disconnect
  ipSelectResult : Tc3_EventLogger.I_TcMessage;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[// --- System time ---
fbLocalSystemTime(bEnable := TRUE);

// --- Write: log each channel on its own interval ---
fbLogTemp(
  id           := 1,
  rValue       := rTemperature,
  nIntervalSec := 10,
  nDbHandle    := GVL_DB.DB_ID,
  stSystemTime := fbLocalSystemTime.systemTime);

fbLogHumid(
  id           := 2,
  rValue       := rHumidity,
  nIntervalSec := 10,
  nDbHandle    := GVL_DB.DB_ID,
  stSystemTime := fbLocalSystemTime.systemTime);

fbLogSpeed(
  id           := 3,
  rValue       := rSpeed,
  nIntervalSec := 10,
  nDbHandle    := GVL_DB.DB_ID,
  stSystemTime := fbLocalSystemTime.systemTime);

// Aggregate write errors for monitoring
GVL_DB.bWriteError := fbLogTemp.bError OR fbLogHumid.bError OR fbLogSpeed.bError;

// --- Read: triggered by setting bSelect := TRUE (e.g. from HMI or Watch window) ---
CASE nSelectState OF

  0: // Idle – waiting for trigger
    IF bSelect THEN
      nSelectState := 1;
    END_IF

  1: // Open connection
    IF fbSelectDb.Connect(GVL_DB.DB_ID) THEN
      ipSelectResult := fbSelectDb.ipTcResult;
      IF fbSelectDb.bError THEN
        bSelectError := TRUE;
        bSelect      := FALSE;
        nSelectState := 5;
      ELSE
        nSelectState := 2;
      END_IF
    END_IF

  2: // Bind command object
    IF fbSelectDb.CreateCmd(ADR(fbSelectCmd)) THEN
      ipSelectResult := fbSelectDb.ipTcResult;
      IF fbSelectDb.bError THEN
        bSelectError := TRUE;
        bSelect      := FALSE;
        nSelectState := 5;
      ELSE
        nSelectState := 3;
      END_IF
    END_IF

  3: // Execute SELECT and link result FB
    IF fbSelectCmd.ExecuteDataReturn(ADR(sSelectCmd), SIZEOF(sSelectCmd), ADR(fbSelectResult)) THEN
      ipSelectResult := fbSelectCmd.ipTcResult;
      IF fbSelectCmd.bError THEN
        bSelectError := TRUE;
        bSelect      := FALSE;
        nSelectState := 5;
      ELSE
        nSelectState := 4;
      END_IF
    END_IF

  4: // Read result rows into arrResults
    IF fbSelectResult.Read(0, GVL_DB.C_MaxSelectRows,
                           ADR(GVL_DB.arrResults), SIZEOF(GVL_DB.arrResults),
                           FALSE, TRUE) THEN
      ipSelectResult := fbSelectResult.ipTcResult;
      IF fbSelectResult.bError THEN
        bSelectError := TRUE;
      ELSE
        bSelectError          := FALSE;
        GVL_DB.nResultCount  := fbSelectResult.nDataCount;
      END_IF
      bSelect      := FALSE;
      nSelectState := 5;
    END_IF

  5: // Disconnect and return to idle
    IF fbSelectDb.Disconnect() THEN
      nSelectState := 0;
    END_IF

END_CASE

bSelectBusy := nSelectState <> 0;
]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>