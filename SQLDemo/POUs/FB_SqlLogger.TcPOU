<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_SqlLogger" Id="{dcd22ad0-bac4-47ce-bcaf-c7b2cf11019f}" SpecialFunc="None">
    <Declaration><![CDATA[// Logs a single REAL value to a database table at a configurable cyclic interval.
// The DB timestamp is generated by MySQL (DEFAULT CURRENT_TIMESTAMP), so no
// system-time formatting is required here.
//
// Required MySQL table:
//   CREATE TABLE ds (
//     id        INT            NOT NULL,
//     timestamp DATETIME       NOT NULL DEFAULT CURRENT_TIMESTAMP,
//     value     FLOAT          NOT NULL
//   );
//
// Tc3_Database SQL Expert Mode: on first call the FB connects to the database
// and initialises a persistent FB_SQLCommandEvt. Subsequent inserts reuse the
// same open connection (states 0-1 run once; state 2 is the steady-state loop).
FUNCTION_BLOCK FB_SqlLogger
VAR_INPUT
  id           : DINT;           // Channel ID written to the 'id' column
  rValue       : REAL;           // Value to log
  nIntervalSec : INT := 10;      // How often to write (seconds)
  sTableName   : STRING := 'ds'; // Target table name
  nDbHandle    : UDINT;     // Database handle (configured in TF6420)
  stSystemTime : TIMESTRUCT;     // Pass fbLocalSystemTime.systemTime here
END_VAR
VAR_OUTPUT
  bBusy      : BOOL;
  bError     : BOOL;
  ipTcResult : Tc3_EventLogger.I_TcMessage;
END_VAR
VAR
  fbSqlDb        : FB_SQLDatabaseEvt(sNetID := '', tTimeout := T#10S);
  fbSqlCmd       : FB_SQLCommandEvt(sNetID := '', tTimeout := T#10S);
  rtrigSecond    : R_TRIG;
  wLastSecond    : WORD;
  nSecondCounter : INT;
  sInsertCmd     : STRING(255);
  bTrigInsert    : BOOL;
  nState         : INT; // 0=connecting, 1=createCmd, 2=ready, 3=executing, 255=error
  tonRetry : TON;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[// Timing: count elapsed seconds and arm the insert trigger
rtrigSecond(CLK := stSystemTime.wSecond <> wLastSecond);
IF rtrigSecond.Q THEN
  wLastSecond := stSystemTime.wSecond;
  nSecondCounter := nSecondCounter + 1;
  IF nSecondCounter >= nIntervalSec THEN
    nSecondCounter := 0;
    // Build: INSERT INTO ds(id,value) VALUES (1,22.5)
    sInsertCmd := CONCAT('INSERT INTO ',
                  CONCAT(sTableName,
                  CONCAT('(id,value) VALUES (',
                  CONCAT(DINT_TO_STRING(id),
                  CONCAT(',',
                  CONCAT(REAL_TO_STRING(rValue), ')'))))));
    IF nState = 2 THEN // only arm when the connection is ready
      bTrigInsert := TRUE;
    END_IF
  END_IF
END_IF

// ── State machine ─────────────────────────────────────────────────────────────
CASE nState OF

  0: // Open connection to the configured database
    bBusy := TRUE;
    IF fbSqlDb.Connect(GVL_DB.DB_ID) THEN
      ipTcResult := fbSqlDb.ipTcResult;
      IF fbSqlDb.bError THEN
        bError := TRUE;
        nState := 255;
      ELSE
        nState := 1;
      END_IF
    END_IF

  1: // Bind a command object to the open connection
    IF fbSqlDb.CreateCmd(ADR(fbSqlCmd)) THEN
      ipTcResult := fbSqlDb.ipTcResult;
      IF fbSqlDb.bError THEN
        bError := TRUE;
        nState := 255;
      ELSE
        bError := FALSE;
        nState := 2;
      END_IF
    END_IF

  2: // Ready – waiting for the next insert trigger
    bBusy := FALSE;
    IF bTrigInsert THEN
      bTrigInsert := FALSE;
      nState := 3;
    END_IF

  3: // Execute the INSERT command asynchronously
    bBusy := TRUE;
    IF fbSqlCmd.Execute(ADR(sInsertCmd), SIZEOF(sInsertCmd)) THEN
      ipTcResult := fbSqlCmd.ipTcResult;
      bError := fbSqlCmd.bError;
      nState := 2; // return to ready regardless of outcome
    END_IF

  255: // Permanent error – connection or command initialisation failed
	  bBusy  := FALSE;
	  bError := TRUE;
	  tonRetry(IN := TRUE, PT := T#10S);
	  IF tonRetry.Q THEN
		tonRetry(IN := FALSE);
		bError := FALSE;
		nState := 0;  // retry connect
	  END_IF

END_CASE
]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>